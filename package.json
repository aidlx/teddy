{
  "name": "teddy",
  "private": true,
  "version": "0.0.1",
  "description": "Teddy — AI startup monorepo (web + mobile + shared packages).",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@teddy/web",
    "dev:mobile": "turbo run dev --filter=@teddy/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  }
}
