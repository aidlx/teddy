# ─────────────────────────────────────────────────────────────
# Supabase — https://supabase.com → create a project → Settings → API
# ─────────────────────────────────────────────────────────────
# Used by Next.js (web). Safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Used by Expo (mobile). Same values as the NEXT_PUBLIC_ ones above.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-side only. NEVER expose in the browser or mobile bundle.
# Use it in API routes / Edge Functions when you need admin privileges.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─────────────────────────────────────────────────────────────
# OpenAI — https://platform.openai.com/api-keys
# ─────────────────────────────────────────────────────────────
# Server-side only. NEVER ship to web bundle or mobile bundle.
# AI calls go through Next.js route handlers or Supabase edge functions.
OPENAI_API_KEY=sk-YOUR_KEY
